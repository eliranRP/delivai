# Shopify App
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_APP_URL=https://your-app-url.fly.dev
SHOPIFY_SCOPES=read_orders,write_orders,read_customers,write_customers,read_products

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/delivai

# Encryption (32-byte hex for AES-256-GCM)
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here_generate_with_openssl

# Session
SESSION_SECRET=your_long_random_session_secret_min_32_chars

# Node
NODE_ENV=development
