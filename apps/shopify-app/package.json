{
  "name": "shopify-app",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "shopify app dev",
    "build": "remix vite:build && tsx scripts/build-widget.mts",
    "build:widget": "tsx scripts/build-widget.mts",
    "build:widget:watch": "tsx scripts/build-widget.mts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "remix-serve ./build/server/index.js",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "typecheck": "tsc --noEmit",
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.33.1",
    "@delivai/shared-types": "workspace:*",
    "@easypost/api": "^8.8.0",
    "@prisma/client": "^5.22.0",
    "@shopify/shopify-app-remix": "^3.4.0",
    "@shopify/shopify-app-session-storage-prisma": "^5.1.3",
    "@shopify/polaris": "^13.9.2",
    "@shopify/app-bridge-react": "^4.1.6",
    "isbot": "^5.1.17",
    "openai": "^4.76.3",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@remix-run/node": "^2.15.0",
    "@remix-run/react": "^2.15.0",
    "@remix-run/serve": "^2.15.0",
    "vite-tsconfig-paths": "^5.1.4",
    "@upstash/redis": "^1.34.3",
    "@upstash/ratelimit": "^2.0.5",
    "@sentry/remix": "^8.47.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.15.0",
    "@shopify/cli": "^3.72.3",
    "@types/react": "^18.3.13",
    "@types/react-dom": "^18.3.1",
    "prisma": "^5.22.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
