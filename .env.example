# ─────────────────────────────────────────────────────────────────────────────
# DelivAI — Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Shopify App ───────────────────────────────────────────────────────────────
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here
SHOPIFY_APP_URL=https://delivai-shopify-app.fly.dev

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL with pgvector extension enabled (Railway / Supabase recommended)
# Supabase: Settings → Database → Connection string → URI
DATABASE_URL=postgresql://user:password@host:5432/delivai?sslmode=require

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
# Used to encrypt merchant Claude API keys + EasyPost keys at rest (AES-256-GCM)
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# Session signing secret — generate: openssl rand -hex 32
SESSION_SECRET=your_session_secret_here

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Used for rate limiting + SSE pub/sub. Optional — app degrades gracefully without it.
# Get from: console.upstash.com → Create Database → REST API
REDIS_URL=https://your-redis-endpoint.upstash.io
REDIS_TOKEN=your_upstash_redis_token_here

# ── Monitoring ────────────────────────────────────────────────────────────────
# Sentry DSN — get from: sentry.io → New Project → Node.js
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# ── OpenAI (for embeddings / RAG) ─────────────────────────────────────────────
# Used to generate product catalog embeddings for the knowledge base
# Note: This is the PLATFORM key — distinct from each merchant's BYOK Claude key
OPENAI_API_KEY=sk-your_openai_key_here

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# Quick-start commands:
#
# 1. Generate encryption key:
#    openssl rand -hex 32
#
# 2. Set Fly.io secrets:
#    fly secrets set DATABASE_URL="..." SHOPIFY_API_KEY="..." \
#      SHOPIFY_API_SECRET="..." ENCRYPTION_KEY="..." \
#      SESSION_SECRET="..." OPENAI_API_KEY="..."
#
# 3. Enable pgvector on Supabase:
#    Run in Supabase SQL editor:
#      CREATE EXTENSION IF NOT EXISTS vector;
#
# 4. Run migrations:
#    pnpm --filter shopify-app migrate:deploy
#
# 5. Deploy:
#    fly deploy --config apps/shopify-app/fly.toml
# ─────────────────────────────────────────────────────────────────────────────
